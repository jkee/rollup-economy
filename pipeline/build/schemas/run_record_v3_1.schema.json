{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "run_record_v3_1.schema.json",
  "title": "v3.1 finalized run record — deterministic inputs and scores injected by Python",
  "type": "object",
  "required": [
    "naics",
    "title",
    "run_meta",
    "dataset_inputs",
    "inputs",
    "scores",
    "S",
    "cross_checks",
    "confidence_overall",
    "heterogeneous",
    "top_uncertain_inputs",
    "reviewer_note"
  ],
  "additionalProperties": false,
  "properties": {
    "naics": { "type": "string", "pattern": "^[0-9]{6}$" },
    "title": { "type": "string", "minLength": 1 },
    "run_meta": {
      "type": "object",
      "required": [
        "model_id",
        "run_date",
        "run_id",
        "template_version",
        "prompt_version",
        "finalizer_version"
      ],
      "additionalProperties": false,
      "properties": {
        "model_id": { "type": "string", "minLength": 1 },
        "run_date": { "type": "string", "format": "date" },
        "run_id": { "type": "string", "minLength": 1 },
        "template_version": { "const": "3.1" },
        "prompt_version": { "type": "string", "minLength": 1 },
        "finalizer_version": { "const": "finalizer-3.1" }
      }
    },
    "dataset_inputs": {
      "type": "object",
      "required": ["labor_share", "role_mix", "n_total", "n_band"],
      "additionalProperties": false,
      "properties": {
        "labor_share": { "$ref": "#/definitions/dataset_value" },
        "role_mix": { "type": "object" },
        "n_total": { "$ref": "#/definitions/dataset_value" },
        "n_band": { "$ref": "#/definitions/dataset_value" }
      }
    },
    "inputs": {
      "type": "object",
      "required": [
        "ai_replaceable_share",
        "pi_dist",
        "pi_moat",
        "t50_years",
        "current_adoption_pct",
        "historical_analogs",
        "owners_60plus_pct",
        "active_consolidators",
        "buy_mult",
        "exit_mult",
        "pricing_structure"
      ],
      "additionalProperties": false,
      "properties": {
        "ai_replaceable_share": { "$ref": "#/definitions/final_role_input" },
        "pi_dist": { "$ref": "#/definitions/judgment_input" },
        "pi_moat": { "$ref": "#/definitions/judgment_input" },
        "t50_years": { "$ref": "#/definitions/research_input" },
        "current_adoption_pct": { "$ref": "#/definitions/research_input" },
        "historical_analogs": { "$ref": "#/definitions/research_input" },
        "owners_60plus_pct": { "$ref": "#/definitions/owners_input" },
        "active_consolidators": { "$ref": "#/definitions/research_input" },
        "buy_mult": { "$ref": "#/definitions/research_input" },
        "exit_mult": { "$ref": "#/definitions/research_input" },
        "pricing_structure": { "$ref": "#/definitions/research_input" }
      }
    },
    "scores": {
      "type": "object",
      "required": ["V", "C", "A", "B", "M"],
      "additionalProperties": false,
      "properties": {
        "V": { "$ref": "#/definitions/factor_score" },
        "C": { "$ref": "#/definitions/factor_score" },
        "A": { "$ref": "#/definitions/factor_score" },
        "B": { "$ref": "#/definitions/factor_score" },
        "M": { "$ref": "#/definitions/factor_score" }
      }
    },
    "S": { "type": "number", "minimum": 0, "maximum": 10 },
    "cross_checks": {
      "type": "object",
      "required": [
        "uplift_pp",
        "uplift_vs_A_consistent",
        "terminal_value",
        "no_proxy_confirmed",
        "pricing_model_deflation"
      ],
      "additionalProperties": false,
      "properties": {
        "uplift_pp": { "type": "number" },
        "uplift_vs_A_consistent": { "type": "string", "minLength": 1 },
        "terminal_value": {
          "type": "object",
          "required": ["class", "justification"],
          "additionalProperties": false,
          "properties": {
            "class": { "enum": ["DURABLE", "PRESSURED", "MELTING"] },
            "justification": { "type": "string", "minLength": 1 }
          }
        },
        "no_proxy_confirmed": { "type": "string", "minLength": 1 },
        "pricing_model_deflation": { "type": "string", "minLength": 1 }
      }
    },
    "confidence_overall": { "enum": ["HIGH", "MED", "LOW"] },
    "heterogeneous": { "type": "boolean" },
    "top_uncertain_inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["input", "plausible_range", "score_impact"],
        "additionalProperties": false,
        "properties": {
          "input": { "type": "string", "minLength": 1 },
          "plausible_range": { "type": "string", "minLength": 1 },
          "score_impact": { "type": "string", "minLength": 1 }
        }
      },
      "contains": {
        "type": "object",
        "properties": { "input": { "const": "t50_years" } },
        "required": ["input"]
      }
    },
    "reviewer_note": { "type": "string" }
  },
  "definitions": {
    "provenance_type": { "enum": ["DIRECT", "DERIVED", "ESTIMATE"] },
    "evidence_quality": { "enum": ["HIGH", "MED", "LOW", "NONE"] },
    "citation": {
      "type": "object",
      "required": ["url", "title", "figure_quoted", "access_date", "scope"],
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "pattern": "^https?://", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "figure_quoted": { "type": "string", "minLength": 1 },
        "access_date": { "type": "string", "format": "date" },
        "scope": { "type": "string", "minLength": 1 }
      }
    },
    "research_input": {
      "type": "object",
      "required": [
        "value",
        "provenance_type",
        "evidence_quality",
        "source_fact",
        "derivation",
        "plausible_range",
        "citations"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {},
        "provenance_type": { "$ref": "#/definitions/provenance_type" },
        "evidence_quality": { "$ref": "#/definitions/evidence_quality" },
        "source_fact": { "type": "string", "minLength": 1 },
        "derivation": { "type": "string", "minLength": 1 },
        "plausible_range": { "type": "string", "minLength": 1 },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/definitions/citation" }
        }
      },
      "if": {
        "properties": {
          "provenance_type": { "enum": ["DIRECT", "DERIVED"] }
        },
        "required": ["provenance_type"]
      },
      "then": {
        "properties": {
          "citations": { "minItems": 1 }
        }
      }
    },
    "owners_input": {
      "type": "object",
      "required": [
        "value",
        "provenance_type",
        "evidence_quality",
        "source_fact",
        "derivation",
        "plausible_range",
        "citations",
        "succession_shortage_documented"
      ],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "number", "minimum": 0, "maximum": 1 },
        "provenance_type": { "$ref": "#/definitions/provenance_type" },
        "evidence_quality": { "$ref": "#/definitions/evidence_quality" },
        "source_fact": { "type": "string", "minLength": 1 },
        "derivation": { "type": "string", "minLength": 1 },
        "plausible_range": { "type": "string", "minLength": 1 },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/definitions/citation" }
        },
        "succession_shortage_documented": {
          "type": "object",
          "required": ["value", "evidence"],
          "additionalProperties": false,
          "properties": {
            "value": { "type": "boolean" },
            "evidence": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "judgment_input": {
      "type": "object",
      "required": [
        "value",
        "rationale",
        "provenance_type",
        "evidence_quality",
        "source_fact",
        "derivation",
        "plausible_range",
        "citations"
      ],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "number", "minimum": 0, "maximum": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "provenance_type": { "$ref": "#/definitions/provenance_type" },
        "evidence_quality": { "$ref": "#/definitions/evidence_quality" },
        "source_fact": { "type": "string", "minLength": 1 },
        "derivation": { "type": "string", "minLength": 1 },
        "plausible_range": { "type": "string", "minLength": 1 },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/definitions/citation" }
        }
      }
    },
    "final_role_input": {
      "type": "object",
      "required": [
        "value",
        "breakdown_by_role",
        "provenance_type",
        "evidence_quality",
        "source_fact",
        "derivation",
        "citations"
      ],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "number", "minimum": 0, "maximum": 1 },
        "breakdown_by_role": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "soc",
              "role",
              "labor_share_of_total",
              "within_role_automatable_fraction",
              "contribution",
              "rationale",
              "plausible_range"
            ],
            "additionalProperties": false,
            "properties": {
              "soc": { "type": "string", "pattern": "^([0-9]{2}-[0-9]{4}|RESIDUAL)$" },
              "role": { "type": "string", "minLength": 1 },
              "labor_share_of_total": { "type": "number", "minimum": 0, "maximum": 1 },
              "within_role_automatable_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
              "contribution": { "type": "number", "minimum": 0, "maximum": 1 },
              "rationale": { "type": "string", "minLength": 1 },
              "plausible_range": { "type": "string", "minLength": 1 }
            }
          }
        },
        "provenance_type": { "$ref": "#/definitions/provenance_type" },
        "evidence_quality": { "$ref": "#/definitions/evidence_quality" },
        "source_fact": { "type": "string", "minLength": 1 },
        "derivation": { "type": "string", "minLength": 1 },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/definitions/citation" }
        }
      }
    },
    "dataset_value": {
      "type": "object",
      "required": ["value"],
      "properties": {
        "value": { "type": "number" }
      }
    },
    "factor_score": {
      "type": "object",
      "required": ["arithmetic", "score"],
      "additionalProperties": false,
      "properties": {
        "arithmetic": { "type": "string", "minLength": 1 },
        "score": { "type": "number", "minimum": 0, "maximum": 10 }
      }
    }
  }
}
