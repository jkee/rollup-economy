{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "research_draft_v3_1_1.schema.json",
  "title": "v3.1.1 research draft — atomic facts plus explicit selection methods",
  "description": "The model authors atomic fetched facts and selected inputs. It does not author provenance labels, deterministic dataset inputs, arithmetic, scores or S. Python assigns final provenance and recomputes every CALCULATED selection.",
  "type": "object",
  "required": [
    "naics",
    "title",
    "run_meta",
    "evidence_facts",
    "dataset_fallbacks",
    "inputs",
    "cross_checks",
    "disclosures",
    "confidence_overall",
    "heterogeneous",
    "top_uncertain_inputs",
    "reviewer_note"
  ],
  "additionalProperties": false,
  "properties": {
    "naics": { "type": "string", "pattern": "^[0-9]{6}$" },
    "title": { "type": "string", "minLength": 1 },
    "run_meta": {
      "type": "object",
      "required": ["model_id", "run_date", "run_id", "template_version", "prompt_version"],
      "additionalProperties": false,
      "properties": {
        "model_id": {
          "enum": ["gpt-5.6-terra", "gpt-5.6-sol"],
          "description": "Exact authorized runtime model ID. Campaign routing binds Terra to fleet and Sol to golden research."
        },
        "run_date": { "type": "string", "format": "date", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "run_id": { "type": "string", "minLength": 1 },
        "template_version": { "const": "3.1.1" },
        "prompt_version": { "type": "string", "minLength": 1 }
      }
    },
    "evidence_facts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/evidence_fact" }
    },
    "dataset_fallbacks": {
      "type": "object",
      "description": "Normally empty. A fallback is allowed only when the deterministic dataset value is null; the finalizer enforces that rule.",
      "additionalProperties": false,
      "properties": {
        "labor_share": { "$ref": "#/definitions/nonnegative_number_selection" },
        "n_band": { "$ref": "#/definitions/nonnegative_integer_selection" }
      }
    },
    "inputs": {
      "type": "object",
      "required": [
        "ai_replaceable_share",
        "pi_dist",
        "pi_moat",
        "t50_years",
        "current_adoption_pct",
        "historical_analogs",
        "owners_60plus_pct",
        "active_consolidators",
        "buy_mult",
        "exit_mult",
        "pricing_structure"
      ],
      "additionalProperties": false,
      "properties": {
        "ai_replaceable_share": { "$ref": "#/definitions/role_judgment_set" },
        "pi_dist": { "$ref": "#/definitions/fraction_selection" },
        "pi_moat": { "$ref": "#/definitions/fraction_selection" },
        "t50_years": { "$ref": "#/definitions/nonnegative_number_selection" },
        "current_adoption_pct": { "$ref": "#/definitions/fraction_selection" },
        "historical_analogs": { "$ref": "#/definitions/string_selection" },
        "owners_60plus_pct": { "$ref": "#/definitions/owners_selection" },
        "active_consolidators": { "$ref": "#/definitions/nonnegative_integer_selection" },
        "buy_mult": { "$ref": "#/definitions/positive_number_selection" },
        "exit_mult": { "$ref": "#/definitions/positive_number_selection" },
        "pricing_structure": { "$ref": "#/definitions/string_selection" }
      }
    },
    "cross_checks": {
      "type": "object",
      "required": [
        "uplift_vs_A_consistent",
        "terminal_value",
        "no_proxy_confirmed",
        "pricing_model_deflation"
      ],
      "additionalProperties": false,
      "properties": {
        "uplift_vs_A_consistent": { "type": "string", "minLength": 1 },
        "terminal_value": {
          "type": "object",
          "required": ["class", "justification"],
          "additionalProperties": false,
          "properties": {
            "class": { "enum": ["DURABLE", "PRESSURED", "MELTING"] },
            "justification": { "type": "string", "minLength": 1 }
          }
        },
        "no_proxy_confirmed": { "type": "string", "minLength": 1 },
        "pricing_model_deflation": { "type": "string", "minLength": 1 }
      }
    },
    "disclosures": { "$ref": "#/definitions/disclosures" },
    "confidence_overall": { "enum": ["HIGH", "MED", "LOW"] },
    "heterogeneous": { "type": "boolean" },
    "top_uncertain_inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["input", "plausible_range", "score_impact"],
        "additionalProperties": false,
        "properties": {
          "input": { "type": "string", "minLength": 1 },
          "plausible_range": { "type": "string", "minLength": 1 },
          "score_impact": { "type": "string", "minLength": 1 }
        }
      },
      "contains": {
        "type": "object",
        "properties": { "input": { "const": "t50_years" } },
        "required": ["input"]
      }
    },
    "reviewer_note": { "type": "string" }
  },
  "definitions": {
    "evidence_quality": {
      "enum": ["HIGH", "MED", "LOW", "NONE"],
      "description": "Reliability of the referenced evidence facts. NONE is required when fact_ids is empty."
    },
    "scope": {
      "type": "object",
      "required": ["population", "geography", "unit", "period", "industry_mismatch"],
      "additionalProperties": false,
      "properties": {
        "population": { "type": "string", "minLength": 1 },
        "geography": { "type": "string", "minLength": 1, "description": "Use 'not reported' when the source does not state geography." },
        "unit": { "type": "string", "minLength": 1 },
        "period": { "type": "string", "minLength": 1 },
        "industry_mismatch": { "type": "string", "minLength": 1 }
      }
    },
    "evidence_fact": {
      "type": "object",
      "required": ["id", "url", "title", "quote", "access_date", "scope"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^F[1-9][0-9]*$" },
        "url": { "type": "string", "pattern": "^https?://", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "quote": { "type": "string", "minLength": 1, "description": "One exact contiguous excerpt or table value. Ellipses are forbidden." },
        "access_date": { "type": "string", "format": "date", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "scope": { "$ref": "#/definitions/scope" }
      }
    },
    "operand": {
      "type": "object",
      "required": ["name", "value", "fact_id"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
        "value": { "type": "number" },
        "fact_id": { "type": "string", "pattern": "^F[1-9][0-9]*$" }
      }
    },
    "calculation": {
      "type": "object",
      "required": ["expression", "operands"],
      "additionalProperties": false,
      "properties": {
        "expression": { "type": "string", "minLength": 1, "description": "Arithmetic expression using only operand names, numeric constants, parentheses and + - * /." },
        "operands": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/operand" }
        }
      }
    },
    "estimate_basis": {
      "type": "object",
      "required": ["starting_fact_ids", "scope_mismatches", "bridge_steps", "judgment_step"],
      "additionalProperties": false,
      "properties": {
        "starting_fact_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^F[1-9][0-9]*$" },
          "description": "Every background fact used in the estimate; must match fact_ids exactly."
        },
        "scope_mismatches": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "Enumerate population/geography/unit/period/industry mismatches, or use one explicit 'none' entry."
        },
        "bridge_steps": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "Ordered proxy, normalization and population-mapping steps from facts to the judgment."
        },
        "judgment_step": {
          "type": "string",
          "minLength": 1,
          "description": "The explicit non-reproducible step that makes the selected value an estimate."
        }
      }
    },
    "selection": {
      "type": "object",
      "required": ["value", "method", "evidence_quality", "fact_ids", "rationale", "plausible_range"],
      "additionalProperties": false,
      "properties": {
        "value": {},
        "method": {
          "enum": ["OBSERVED", "CALCULATED", "ESTIMATE"],
          "description": "OBSERVED equals a source value; CALCULATED is fully machine-reproducible; any judgmental mapping is ESTIMATE."
        },
        "evidence_quality": { "$ref": "#/definitions/evidence_quality" },
        "fact_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^F[1-9][0-9]*$" }
        },
        "rationale": { "type": "string", "minLength": 1 },
        "plausible_range": { "type": "string", "minLength": 1 },
        "observed_value": {},
        "calculation": { "$ref": "#/definitions/calculation" },
        "estimate_basis": { "$ref": "#/definitions/estimate_basis" }
      },
      "if": {
        "properties": { "method": { "const": "OBSERVED" } },
        "required": ["method"]
      },
      "then": {
        "required": ["observed_value"],
        "properties": { "fact_ids": { "minItems": 1 } }
      },
      "else": {
        "if": {
          "properties": { "method": { "const": "CALCULATED" } },
          "required": ["method"]
        },
        "then": {
          "required": ["calculation"],
          "properties": { "fact_ids": { "minItems": 1 } }
        },
        "else": { "required": ["estimate_basis"] }
      }
    },
    "nonnegative_number_selection": {
      "allOf": [
        { "$ref": "#/definitions/selection" },
        { "properties": { "value": { "type": "number", "minimum": 0 } } }
      ]
    },
    "fraction_selection": {
      "allOf": [
        { "$ref": "#/definitions/selection" },
        { "properties": { "value": { "type": "number", "minimum": 0, "maximum": 1 } } }
      ]
    },
    "positive_number_selection": {
      "allOf": [
        { "$ref": "#/definitions/selection" },
        { "properties": { "value": { "type": "number", "exclusiveMinimum": 0 } } }
      ]
    },
    "nonnegative_integer_selection": {
      "allOf": [
        { "$ref": "#/definitions/selection" },
        { "properties": { "value": { "type": "integer", "minimum": 0 } } }
      ]
    },
    "string_selection": {
      "allOf": [
        { "$ref": "#/definitions/selection" },
        { "properties": { "value": { "type": "string", "minLength": 1 } } }
      ]
    },
    "owners_selection": {
      "type": "object",
      "required": ["selection", "succession_shortage_documented"],
      "additionalProperties": false,
      "properties": {
        "selection": { "$ref": "#/definitions/fraction_selection" },
        "succession_shortage_documented": { "$ref": "#/definitions/boolean_selection" }
      }
    },
    "boolean_selection": {
      "allOf": [
        { "$ref": "#/definitions/selection" },
        { "properties": { "value": { "type": "boolean" } } }
      ],
      "description": "Score-affecting succession-shortage flag under the same fact/method contract as every other selected input. CALCULATED is semantically rejected because the value is nonnumeric."
    },
    "role_judgment_set": {
      "type": "object",
      "required": ["role_judgments", "evidence_quality", "fact_ids", "estimate_basis"],
      "additionalProperties": false,
      "properties": {
        "role_judgments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["soc", "within_role_automatable_fraction", "rationale", "plausible_range"],
            "additionalProperties": false,
            "properties": {
              "soc": { "type": "string", "pattern": "^([0-9]{2}-[0-9]{4}|RESIDUAL)$" },
              "within_role_automatable_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
              "rationale": { "type": "string", "minLength": 1 },
              "plausible_range": { "type": "string", "minLength": 1 }
            }
          }
        },
        "evidence_quality": { "$ref": "#/definitions/evidence_quality" },
        "fact_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^F[1-9][0-9]*$" }
        },
        "estimate_basis": { "$ref": "#/definitions/estimate_basis" }
      }
    },
    "sensitivity_case": {
      "type": "object",
      "required": ["input", "alternative_value", "impact"],
      "additionalProperties": false,
      "properties": {
        "input": { "type": "string", "minLength": 1 },
        "alternative_value": {},
        "impact": { "type": "string", "minLength": 1 }
      }
    },
    "subsegment": {
      "type": "object",
      "required": ["name", "revenue_rank", "evidence_or_uncertainty"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "revenue_rank": { "type": "integer", "minimum": 1 },
        "evidence_or_uncertainty": { "type": "string", "minLength": 1 }
      }
    },
    "disclosures": {
      "type": "object",
      "required": ["dataset_mismatch", "market_boundary"],
      "additionalProperties": false,
      "properties": {
        "dataset_mismatch": {
          "type": "object",
          "required": ["applies", "description", "sensitivity"],
          "additionalProperties": false,
          "properties": {
            "applies": { "type": "boolean" },
            "description": { "type": "string" },
            "sensitivity": {
              "type": "array",
              "items": { "$ref": "#/definitions/sensitivity_case" }
            }
          },
          "if": { "properties": { "applies": { "const": true } }, "required": ["applies"] },
          "then": {
            "properties": {
              "description": { "minLength": 1 },
              "sensitivity": { "minItems": 1 }
            }
          },
          "else": { "properties": { "sensitivity": { "maxItems": 0 } } }
        },
        "market_boundary": {
          "type": "object",
          "required": ["applies", "subsegments", "dominant_subsegment", "selection_basis"],
          "additionalProperties": false,
          "properties": {
            "applies": { "type": "boolean" },
            "subsegments": {
              "type": "array",
              "items": { "$ref": "#/definitions/subsegment" }
            },
            "dominant_subsegment": { "type": "string" },
            "selection_basis": { "type": "string" }
          },
          "if": { "properties": { "applies": { "const": true } }, "required": ["applies"] },
          "then": {
            "properties": {
              "subsegments": { "minItems": 3 },
              "dominant_subsegment": { "minLength": 1 },
              "selection_basis": { "minLength": 1 }
            }
          },
          "else": { "properties": { "subsegments": { "maxItems": 0 } } }
        }
      }
    }
  }
}
