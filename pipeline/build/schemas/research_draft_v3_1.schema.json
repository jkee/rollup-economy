{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "research_draft_v3_1.schema.json",
  "title": "v3.1 research draft — model-authored evidence and judgments only",
  "description": "The research runner writes this artifact. It intentionally excludes deterministic dataset inputs, arithmetic, factor scores and S; pipeline/build/finalize_run_v3_1.py injects and computes those fields.",
  "type": "object",
  "required": [
    "naics",
    "title",
    "run_meta",
    "dataset_fallbacks",
    "inputs",
    "cross_checks",
    "confidence_overall",
    "heterogeneous",
    "top_uncertain_inputs",
    "reviewer_note"
  ],
  "additionalProperties": false,
  "properties": {
    "naics": { "type": "string", "pattern": "^[0-9]{6}$" },
    "title": { "type": "string", "minLength": 1 },
    "run_meta": {
      "type": "object",
      "required": ["model_id", "run_date", "run_id", "template_version", "prompt_version"],
      "additionalProperties": false,
      "properties": {
        "model_id": { "type": "string", "minLength": 1 },
        "run_date": { "type": "string", "format": "date" },
        "run_id": { "type": "string", "minLength": 1 },
        "template_version": { "const": "3.1" },
        "prompt_version": { "type": "string", "minLength": 1 }
      }
    },
    "dataset_fallbacks": {
      "type": "object",
      "description": "Normally empty. A fallback is permitted only when the corresponding deterministic dataset value is null; the finalizer enforces that rule.",
      "additionalProperties": false,
      "properties": {
        "labor_share": { "$ref": "#/definitions/nonnegative_number_input" },
        "n_band": { "$ref": "#/definitions/nonnegative_integer_input" }
      }
    },
    "inputs": {
      "type": "object",
      "required": [
        "ai_replaceable_share",
        "pi_dist",
        "pi_moat",
        "t50_years",
        "current_adoption_pct",
        "historical_analogs",
        "owners_60plus_pct",
        "active_consolidators",
        "buy_mult",
        "exit_mult",
        "pricing_structure"
      ],
      "additionalProperties": false,
      "properties": {
        "ai_replaceable_share": { "$ref": "#/definitions/role_judgment_set" },
        "pi_dist": { "$ref": "#/definitions/judgment_input" },
        "pi_moat": { "$ref": "#/definitions/judgment_input" },
        "t50_years": { "$ref": "#/definitions/nonnegative_number_input" },
        "current_adoption_pct": { "$ref": "#/definitions/fraction_input" },
        "historical_analogs": { "$ref": "#/definitions/string_input" },
        "owners_60plus_pct": { "$ref": "#/definitions/owners_input" },
        "active_consolidators": { "$ref": "#/definitions/nonnegative_integer_input" },
        "buy_mult": { "$ref": "#/definitions/positive_number_input" },
        "exit_mult": { "$ref": "#/definitions/positive_number_input" },
        "pricing_structure": { "$ref": "#/definitions/string_input" }
      }
    },
    "cross_checks": {
      "type": "object",
      "required": [
        "uplift_vs_A_consistent",
        "terminal_value",
        "no_proxy_confirmed",
        "pricing_model_deflation"
      ],
      "additionalProperties": false,
      "properties": {
        "uplift_vs_A_consistent": { "type": "string", "minLength": 1 },
        "terminal_value": {
          "type": "object",
          "required": ["class", "justification"],
          "additionalProperties": false,
          "properties": {
            "class": { "enum": ["DURABLE", "PRESSURED", "MELTING"] },
            "justification": { "type": "string", "minLength": 1 }
          }
        },
        "no_proxy_confirmed": { "type": "string", "minLength": 1 },
        "pricing_model_deflation": { "type": "string", "minLength": 1 }
      }
    },
    "confidence_overall": { "enum": ["HIGH", "MED", "LOW"] },
    "heterogeneous": { "type": "boolean" },
    "top_uncertain_inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["input", "plausible_range", "score_impact"],
        "additionalProperties": false,
        "properties": {
          "input": { "type": "string", "minLength": 1 },
          "plausible_range": { "type": "string", "minLength": 1 },
          "score_impact": { "type": "string", "minLength": 1 }
        }
      },
      "contains": {
        "type": "object",
        "properties": { "input": { "const": "t50_years" } },
        "required": ["input"]
      }
    },
    "reviewer_note": { "type": "string" }
  },
  "definitions": {
    "provenance_type": {
      "enum": ["DIRECT", "DERIVED", "ESTIMATE"],
      "description": "How selected_value relates to evidence: DIRECT is stated by a cited source; DERIVED is calculated or normalized from cited source facts; ESTIMATE is an openly declared judgment that no source directly establishes."
    },
    "evidence_quality": {
      "enum": ["HIGH", "MED", "LOW", "NONE"],
      "description": "Reliability of the evidence base, independent of provenance_type. NONE means no citation supports the estimate."
    },
    "citation": {
      "type": "object",
      "required": ["url", "title", "figure_quoted", "access_date", "scope"],
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "pattern": "^https?://", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "figure_quoted": {
          "type": "string",
          "minLength": 1,
          "description": "A short exact excerpt or table value personally verified on the fetched page."
        },
        "access_date": { "type": "string", "format": "date" },
        "scope": {
          "type": "string",
          "minLength": 1,
          "description": "Population, geography, unit, time period and any mismatch to the target NAICS."
        }
      }
    },
    "research_input": {
      "type": "object",
      "required": [
        "value",
        "provenance_type",
        "evidence_quality",
        "source_fact",
        "derivation",
        "plausible_range",
        "citations"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {},
        "provenance_type": { "$ref": "#/definitions/provenance_type" },
        "evidence_quality": { "$ref": "#/definitions/evidence_quality" },
        "source_fact": {
          "type": "string",
          "minLength": 1,
          "description": "Only what the citations actually establish; never the adjusted selected value unless provenance_type is DIRECT."
        },
        "derivation": {
          "type": "string",
          "minLength": 1,
          "description": "Complete bridge from source_fact to value. For an unsourced ESTIMATE, state the basis and that no source establishes the value."
        },
        "plausible_range": { "type": "string", "minLength": 1 },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/definitions/citation" }
        }
      },
      "if": {
        "properties": {
          "provenance_type": { "enum": ["DIRECT", "DERIVED"] }
        },
        "required": ["provenance_type"]
      },
      "then": {
        "properties": {
          "citations": { "minItems": 1 }
        }
      }
    },
    "nonnegative_number_input": {
      "allOf": [
        { "$ref": "#/definitions/research_input" },
        {
          "properties": {
            "value": { "type": "number", "minimum": 0 }
          }
        }
      ]
    },
    "fraction_input": {
      "allOf": [
        { "$ref": "#/definitions/research_input" },
        {
          "properties": {
            "value": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      ]
    },
    "positive_number_input": {
      "allOf": [
        { "$ref": "#/definitions/research_input" },
        {
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      ]
    },
    "nonnegative_integer_input": {
      "allOf": [
        { "$ref": "#/definitions/research_input" },
        {
          "properties": {
            "value": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "string_input": {
      "allOf": [
        { "$ref": "#/definitions/research_input" },
        {
          "properties": {
            "value": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "owners_input": {
      "type": "object",
      "required": [
        "value",
        "provenance_type",
        "evidence_quality",
        "source_fact",
        "derivation",
        "plausible_range",
        "citations",
        "succession_shortage_documented"
      ],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "number", "minimum": 0, "maximum": 1 },
        "provenance_type": { "$ref": "#/definitions/provenance_type" },
        "evidence_quality": { "$ref": "#/definitions/evidence_quality" },
        "source_fact": { "type": "string", "minLength": 1 },
        "derivation": { "type": "string", "minLength": 1 },
        "plausible_range": { "type": "string", "minLength": 1 },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/definitions/citation" }
        },
        "succession_shortage_documented": {
          "type": "object",
          "required": ["value", "evidence"],
          "additionalProperties": false,
          "properties": {
            "value": { "type": "boolean" },
            "evidence": { "type": "string", "minLength": 1 }
          }
        }
      },
      "if": {
        "properties": {
          "provenance_type": { "enum": ["DIRECT", "DERIVED"] }
        },
        "required": ["provenance_type"]
      },
      "then": {
        "properties": {
          "citations": { "minItems": 1 }
        }
      }
    },
    "judgment_input": {
      "type": "object",
      "required": [
        "value",
        "rationale",
        "provenance_type",
        "evidence_quality",
        "source_fact",
        "derivation",
        "plausible_range",
        "citations"
      ],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "number", "minimum": 0, "maximum": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "provenance_type": { "$ref": "#/definitions/provenance_type" },
        "evidence_quality": { "$ref": "#/definitions/evidence_quality" },
        "source_fact": { "type": "string", "minLength": 1 },
        "derivation": { "type": "string", "minLength": 1 },
        "plausible_range": { "type": "string", "minLength": 1 },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/definitions/citation" }
        }
      },
      "if": {
        "properties": {
          "provenance_type": { "enum": ["DIRECT", "DERIVED"] }
        },
        "required": ["provenance_type"]
      },
      "then": {
        "properties": {
          "citations": { "minItems": 1 }
        }
      }
    },
    "role_judgment_set": {
      "type": "object",
      "required": [
        "role_judgments",
        "provenance_type",
        "evidence_quality",
        "source_fact",
        "derivation",
        "citations"
      ],
      "additionalProperties": false,
      "properties": {
        "role_judgments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "soc",
              "within_role_automatable_fraction",
              "rationale",
              "plausible_range"
            ],
            "additionalProperties": false,
            "properties": {
              "soc": {
                "type": "string",
                "pattern": "^([0-9]{2}-[0-9]{4}|RESIDUAL)$",
                "description": "Must match a supplied SOC exactly. RESIDUAL is the only permitted added row."
              },
              "within_role_automatable_fraction": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "rationale": { "type": "string", "minLength": 1 },
              "plausible_range": { "type": "string", "minLength": 1 }
            }
          }
        },
        "provenance_type": { "$ref": "#/definitions/provenance_type" },
        "evidence_quality": { "$ref": "#/definitions/evidence_quality" },
        "source_fact": { "type": "string", "minLength": 1 },
        "derivation": { "type": "string", "minLength": 1 },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/definitions/citation" }
        }
      },
      "if": {
        "properties": {
          "provenance_type": { "enum": ["DIRECT", "DERIVED"] }
        },
        "required": ["provenance_type"]
      },
      "then": {
        "properties": {
          "citations": { "minItems": 1 }
        }
      }
    }
  }
}
