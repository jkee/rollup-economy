{
  "version": "3.0-draft",
  "frozen": false,
  "score": {
    "type": "geometric_mean",
    "factors": ["V", "C", "A", "B", "M"],
    "scale": [0, 10]
  },
  "verdict_cuts": {
    "hell_yes": 7.0,
    "strong": 5.5,
    "conditional": 4.0,
    "pass": 3.0
  },
  "gates": {
    "hell_yes": {
      "min_each_factor": 6.0,
      "terminal_value": ["DURABLE"],
      "min_confidence": "MED"
    }
  },
  "caps": {
    "terminal_value": { "PRESSURED": "strong", "MELTING": "pass" },
    "confidence": { "LOW": "conditional" }
  },
  "kill": {
    "any_factor_below": 1.0,
    "note": "any factor under this floor is KILL regardless of S (B~0 non-acquirable, C~0 value flows elsewhere)"
  },
  "borderline_epsilon": 0.15,
  "display_precision_decimals": 1,
  "staleness_months": 12
}
